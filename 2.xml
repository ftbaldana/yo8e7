var paymentsData = NO_DATA;
var payments = null;
function InitPayments() {
  return new Promise(function(resolve) {
    try {
      if (!ysdk) { Final(NO_DATA); return; }
      ysdk.getPayments().then(function(_p){
        payments = _p;
        payments.getCatalog().then(function(products){
          payments.getPurchases().then(function(purchases){
            var ids=[],titles=[],descs=[],imgs=[],prs=[],prv=[],codes=[],curl=[],cons=[];
            for (var i=0;i<products.length;i++) {
              ids[i]=products[i].id; titles[i]=products[i].title;
              descs[i]=products[i].description; imgs[i]=products[i].imageURI;
              prs[i]=products[i].price; prv[i]=products[i].priceValue;
              codes[i]=products[i].priceCurrencyCode;
              curl[i]=products[i].getPriceCurrencyImage("medium");
              cons[i]=!purchases.some(function(p){ return p.productID===ids[i]; });
            }
            Final(JSON.stringify({id:ids,title:titles,description:descs,imageURI:imgs,
              price:prs,priceValue:prv,priceCurrencyCode:codes,currencyImageURL:curl,
              consumed:cons, language:ysdk.environment.i18n.lang}));
          });
        });
      }).catch(function(){ Final(NO_DATA); });
    } catch(e) { Final(NO_DATA); }
    function Final(r){ paymentsData=r; YG2Instance('PaymentsEntries',r); resolve(r); }
  });
}
function BuyPayments(id) {
  try {
    if (payments) {
      payments.purchase(id).then(function(){ ConsumePurchase(id,true); FocusGame(); })
        .catch(function(e){ console.error(e); YG2Instance('OnPurchaseFailed',id); FocusGame(); });
    } else YG2Instance('OnPurchaseFailed',id);
  } catch(e) { YG2Instance('OnPurchaseFailed',id); FocusGame(); }
}
function ConsumePurchase(id, success) {
  try {
    if (payments) payments.getPurchases().then(function(ps){
      ps.filter(function(p){ return p.productID===id; }).forEach(function(p){
        payments.consumePurchase(p.purchaseToken);
        if (success) YG2Instance('OnPurchaseSuccess', id);
      });
    });
  } catch(e) { console.error(e); }
}
function ConsumePurchases(success) {
  try {
    if (payments) payments.getPurchases().then(function(ps){
      ps.forEach(function(p){
        payments.consumePurchase(p.purchaseToken);
        if (success) YG2Instance('OnPurchaseSuccess', p.productID);
      });
    });
  } catch(e) { console.error(e); }
}

function SetLeaderboard(name, score, extra) {
  if (!ysdk) return;
  try { ysdk.leaderboards.setScore(name, score, extra); } catch(e) { console.error(e); }
}
function GetLeaderboard(nameLB, quantityTop, quantityAround, photoSize, auth) {
  if (!ysdk) return;
  var entry = { technoName:'', isDefault:false, isInvertSortOrder:false, decimalOffset:0, type:'' };
  ysdk.leaderboards.getDescription(nameLB).then(function(res){
    entry.technoName=nameLB; entry.isDefault=res.default;
    entry.isInvertSortOrder=res.description.invert_sort_order;
    entry.decimalOffset=res.description.score_format.options.decimal_offset;
    entry.type=res.description.type;
    return ysdk.leaderboards.getEntries(nameLB, {quantityTop,includeUser:auth,quantityAround});
  }).then(function(res){
    var j = Object.assign({}, entry, EntriesLB(res, photoSize));
    YG2Instance('LeaderboardEntries', JSON.stringify(j));
  }).catch(console.error);
}
function EntriesLB(res, photoSize) {
  var n=res.entries.length,ranks=[],photos=[],names=[],scores=[],uids=[],extras=[],text='';
  for (var i=0;i<n;i++) {
    ranks[i]=res.entries[i].rank; scores[i]=res.entries[i].score;
    uids[i]=res.entries[i].player.uniqueID;
    photos[i]=res.entries[i].player.getAvatarSrc(photoSize);
    extras[i]=res.entries[i].extraData||NO_DATA;
    names[i]=res.entries[i].player.scopePermissions.public_name==='allow'
      ? res.entries[i].player.publicName : 'anonymous';
    text+=ranks[i]+'. '+names[i]+': '+scores[i]+'\n';
  }
  if (!n) text='no data';
  return {entries:text,ranks,photos,names,scores,uniqueIDs:uids,extraDataArray:extras};
}

